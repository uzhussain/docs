{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Timekeepur Labs",
  "colors": {
    "primary": "#A45F00",
    "light": "#F89D00",
    "dark": "#7E4600"
  },
  "fonts": {
    "family": "Geist",
    "weight": 400,
    "heading": {
      "family": "Geist",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://labs.timekeepur.com"
        },
        {
          "anchor": "X",
          "icon": "x-twitter",
          "href": "https://x.com/timekeepurlabs"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Product",
            "pages": [
              "essentials/navigation"
            ]
          },
          {
            "group": "Pricing",
            "pages": [
              "development",
              "pricing/credit-costs"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/images/Group2014.svg",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@timekeepur.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://labs.timekeepur.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/timekeepurlabs",
      "linkedin": "https://www.linkedin.com/in/uzairhussain/"
    }
  }
}
